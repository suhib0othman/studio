rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read and write only their own assessment results
    match /results/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Referral tracking: Users can read their own, and creation might be needed for new users
    match /referrals/{referralCode} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
